    "sonner": "^2.0.7",
    "stylis": "^4.4.0",
    "three": "^0.182.0",
    "three-globe": "^2.45.2",
    "turndown": "^7.2.4",
    "viem": "^2.53.1",
    "wagmi": "^3.6.19",
    "zod": "^3.25.76"

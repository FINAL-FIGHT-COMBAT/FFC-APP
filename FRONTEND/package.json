    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-resources-to-backend": "^1.2.1",
    "jose": "^6.2.3",
    "minimal-shared": "^1.1.6",
    "next": "^16.2.9",
    "nprogress": "^0.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-i18next": "^16.6.6",
    "react-markdown": "^10.1.0",

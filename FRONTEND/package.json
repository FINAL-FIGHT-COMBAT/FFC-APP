{
  "name": "@ffc/frontend",
  "author": "Final Fight Combat",
  "version": "2.0.0",
  "description": "FFC Official App",
  "private": true,
  "scripts": {
    "dev": "next dev -p 8082 --turbopack",
    "start": "next start -p 8082",
    "build": "next build",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint --fix \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:print": "npx eslint --print-config eslint.config.mjs > eslint-show-config.json",
    "fm:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx}\"",
    "fm:fix": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "fix:all": "npm run lint:fix && npm run fm:fix",
    "clean": "rm -rf node_modules .next out dist build",
    "re:dev": "pnpm clean && pnpm install && pnpm dev",
    "re:build": "pnpm clean && pnpm install && pnpm build",
    "tsc:dev": "pnpm dev & pnpm tsc:watch",
    "tsc:watch": "tsc --noEmit --watch",
    "tsc:print": "npx tsc --showConfig",
    "test": "vitest run"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.4.0",
    "@iconify/react": "^6.0.2",
    "@mui/lab": "7.0.1-beta.21",
    "@mui/material": "^7.3.11",
    "@mui/material-nextjs": "^7.3.10",
    "@mui/stylis-plugin-rtl": "^7.3.10",
    "@mui/system": "^7.3.11",
    "@mui/x-data-grid": "^7.29.13",
    "@mui/x-date-pickers": "^7.29.4",
    "@mui/x-tree-view": "^7.29.10",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tanstack/react-query": "^5.101.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "accept-language": "^3.0.20",
    "autosuggest-highlight": "^3.3.4",
    "axios": "^1.18.1",
    "dayjs": "^1.11.21",
    "embla-carousel": "^8.6.0",
    "embla-carousel-auto-scroll": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",

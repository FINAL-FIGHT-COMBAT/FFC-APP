# ------------------------------------------------------
# 🔒 ARQUIVOS DE CONFIGURAÇÃO SENSÍVEIS (BLOQUEADOS)
# ------------------------------------------------------
# NOTA: IDs de infraestrutura pública podem ser versionados se necessário para CI/CD.
# Wrangler configs são permitidos, mas SEGREDOS (.dev.vars) são terminantemente proibidos.
# wrangler.jsonc e wrangler.toml permanecem versionados para transparência da infraestrutura.

# Segredos e Variáveis de Ambiente (CRÍTICO - NUNCA REMOVA)
.dev.vars
.dev.vars.*
.env
.env.*
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
.envrc

# certificados e chaves privadas
*.pem
*.key
*.pfx
*.crt
*.cer

# arquivos comuns de credenciais
secrets.json
credentials.json
service-account.json

# ------------------------------------------------------
